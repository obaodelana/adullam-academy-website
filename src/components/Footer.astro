---
/**
 * Footer Component
 * 
 * Site footer with contact information, social links, navigation,
 * and branding elements.
 * 
 * Features:
 * - Multi-column responsive layout
 * - Social media links with hover animations
 * - Location and contact information
 * - Newsletter signup (optional)
 * - Quick navigation links
 */

import { REGISTER_LINK } from '../data/links';

// Social links configuration
const socialLinks = [
  {
    name: "Instagram",
    href: "https://www.instagram.com/_adullam.academy_",
    icon: `<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>`
  },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/company/adullamacademy",
    icon: `<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>`
  }
];

// Quick links configuration
const quickLinks = [
  { href: "/", label: "Home" },
  { href: "/bootcamp", label: "Program" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
  { href: "/jobs", label: "Jobs" },
];

const currentYear = new Date().getFullYear();
---

<footer class="bg-linear-to-b from-navy-800 to-navy-950 text-white">
  <!-- Gold accent line -->
  <div class="h-px bg-linear-to-r from-transparent via-gold-500/60 to-transparent"></div>
  <!-- Main Footer Content -->
  <div class="container mx-auto px-4 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      
      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-6 group">
          <div class="relative w-14 h-14 rounded-full bg-white flex items-center justify-center shadow-lg transition-transform duration-300 group-hover:scale-105">
            <img 
              src="/logos/logo-transparent-scaled.png" 
              alt="Adullam Academy Logo" 
              class="h-11 w-auto"
            />
          </div>
          <span class="text-xl font-bold text-white hidden sm:block">
            Adullam Academy
          </span>
        </a>
        <p class="text-white/70 mb-6 leading-relaxed">
          Empowering the next generation of Kingdom visionaries to create.
        </p>
        <p class="text-gold-500 font-semibold italic">
          Jesus is Lord!
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-lg font-bold mb-6 text-gold-400">Quick Links</h3>
        <ul class="space-y-3">
          {quickLinks.map((link) => (
            <li>
              <a 
                href={link.href}
                class="text-white/70 hover:text-white hover:pl-2 transition-all duration-300 inline-block"
              >
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a 
              href={REGISTER_LINK}
              class="text-gold-500 hover:text-gold-400 hover:pl-2 transition-all duration-300 inline-block font-medium"
            >
              Register Now
            </a>
          </li>
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-lg font-bold mb-6 text-gold-400">Contact</h3>
        <p class="text-white/70 text-sm mb-5">
          Based in Canada, serving online globally.
        </p>
        <ul class="space-y-4">
          <li>
            <a 
              href="tel:+17809662026"
              class="flex items-center gap-3 text-white/70 hover:text-white transition-colors duration-300"
            >
              <svg class="w-5 h-5 text-gold-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              +1 (780) 966-2026
            </a>
          </li>
          <li>
            <a 
              href="mailto:info@adullamacademy.com"
              class="flex items-center gap-3 text-white/70 hover:text-white transition-colors duration-300"
            >
              <svg class="w-5 h-5 text-gold-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              info@adullamacademy.com
            </a>
          </li>
        </ul>
      </div>

      <!-- Social & CTA -->
      <div>
        <h3 class="text-lg font-bold mb-6 text-gold-400">Connect</h3>
        <div class="flex gap-4 mb-8">
          {socialLinks.map((social) => (
            <a 
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-gold-500 hover:scale-110 transition-all duration-300 group"
              aria-label={`Visit our ${social.name}`}
            >
              <svg 
                class="w-5 h-5 fill-white/70 group-hover:fill-navy-900 transition-colors duration-300" 
                viewBox="0 0 24 24"
                set:html={social.icon}
              />
            </a>
          ))}
        </div>
        
        <!-- CTA -->
        <div class="p-6 rounded-xl glass-gold">
          <p class="text-white/90 mb-4 text-sm">
            Ready to equip your child for the future?
          </p>
          <a 
            href={REGISTER_LINK}
            class="btn-primary w-full text-center block"
          >
            Enrol Now
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/10">
    <div class="container mx-auto px-4 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-white/50 text-sm text-center md:text-left">
          &copy; {currentYear} Adullam Academy. All rights reserved.
        </p>
        <p class="text-white/50 text-sm">
          Built with <span class="text-gold-500">&hearts;</span> for Kingdom impact
        </p>
      </div>
    </div>
  </div>
</footer>
