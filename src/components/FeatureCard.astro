---
/**
 * FeatureCard Component
 * 
 * A glassmorphic card component for displaying features/approach items.
 * Used in the "Our Approach" section and similar feature grids.
 * 
 * Features:
 * - Glassmorphism design with backdrop blur
 * - Number badge for ordered lists
 * - Hover animations (lift, glow)
 * - Icon support (slot)
 * - Responsive sizing
 * 
 * Props:
 * @prop {string} title - Card title
 * @prop {string} description - Card description text
 * @prop {number} number - Display number (1-4 style badge)
 * @prop {string} icon - Icon slot name or SVG path
 * @prop {number} delay - Animation delay for staggered reveals
 */

interface Props {
  title: string;
  description: string;
  number?: number;
  delay?: number;
}

const { title, description, number, delay = 0 } = Astro.props;
---

<div 
  class="group relative p-8 rounded-2xl glass-dark card-hover animate-on-scroll overflow-hidden"
  style={`animation-delay: ${delay}s;`}
>
  <!-- Gradient border effect on hover -->
  <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"
       style="background: linear-gradient(135deg, rgba(212, 168, 83, 0.3) 0%, transparent 50%, rgba(212, 168, 83, 0.1) 100%); padding: 1px;">
  </div>
  
  <!-- Number badge with enhanced styling -->
  {number && (
    <div class="absolute -top-4 -left-4 w-12 h-12 rounded-full bg-linear-to-br from-gold-400 to-gold-600 text-navy-900 font-bold text-xl flex items-center justify-center shadow-gold group-hover:scale-110 group-hover:shadow-gold-lg transition-all duration-300">
      {number}
    </div>
  )}
  
  <!-- Icon slot with glow effect -->
  <div class="mb-6 text-gold-400 group-hover:text-gold-300 transition-colors duration-300">
    <div class="relative inline-block">
      <slot name="icon">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </slot>
      <!-- Icon glow on hover -->
      <div class="absolute inset-0 bg-gold-500/20 rounded-full blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 -z-10"></div>
    </div>
  </div>
  
  <!-- Content -->
  <h3 class="text-xl font-bold text-white mb-3 group-hover:text-gold-400 transition-colors duration-300">
    {title}
  </h3>
  <p class="text-white/70 leading-relaxed group-hover:text-white/80 transition-colors duration-300">
    {description}
  </p>
  
  <!-- Decorative corner accent - enhanced -->
  <div class="absolute bottom-0 right-0 w-32 h-32 overflow-hidden rounded-br-2xl pointer-events-none">
    <div class="absolute -bottom-16 -right-16 w-32 h-32 bg-gold-500/5 rounded-full group-hover:bg-gold-500/15 group-hover:scale-125 transition-all duration-700"></div>
  </div>
  
  <!-- Top-right subtle accent -->
  <div class="absolute top-0 right-0 w-20 h-20 overflow-hidden rounded-tr-2xl pointer-events-none">
    <div class="absolute -top-10 -right-10 w-20 h-20 bg-electric-500/5 rounded-full group-hover:bg-electric-500/10 transition-colors duration-500"></div>
  </div>
</div>
