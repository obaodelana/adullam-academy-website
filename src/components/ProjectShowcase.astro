---
/**
 * ProjectShowcase Component
 * 
 * A grid display for showcasing student projects with hover effects.
 * Used on the Bootcamp page to show what students build.
 * 
 * Features:
 * - Responsive grid layout
 * - Image/GIF support with hover zoom
 * - Category badges
 * - Staggered reveal animations
 * - Optional filtering by category
 * 
 * Props:
 * @prop {Array} projects - Array of project objects
 * @prop {boolean} showFilters - Whether to show category filters
 */

interface Project {
  title: string;
  category: string;
  description: string;
  image: string;
}

interface Props {
  projects?: Project[];
  showFilters?: boolean;
}

const defaultProjects: Project[] = [
  {
    title: "Galaxy Blast",
    category: "3D Game",
    description: "A space shooter game with stunning visuals and exciting gameplay",
    image: "/images/projects/game-placeholder.svg"
  },
  {
    title: "Scripture Memory App",
    category: "Mobile App",
    description: "An app to help memorize Bible verses with flashcards and quizzes",
    image: "/images/projects/app-placeholder.svg"
  },
  {
    title: "Church Event Website",
    category: "Website",
    description: "A responsive website for managing church events and registrations",
    image: "/images/projects/web-placeholder.svg"
  },
  {
    title: "AI Prayer Partner",
    category: "AI Project",
    description: "An AI chatbot providing Scripture-based encouragement and guidance",
    image: "/images/projects/ai-placeholder.svg"
  },
];

const { projects = defaultProjects, showFilters = false } = Astro.props;

const categories = [...new Set(projects.map(p => p.category))];

// Category colors
const categoryColors: Record<string, string> = {
  "3D Game": "bg-purple-500/20 text-purple-300 border-purple-500/30",
  "Mobile App": "bg-blue-500/20 text-blue-300 border-blue-500/30",
  "Website": "bg-green-500/20 text-green-300 border-green-500/30",
  "AI Project": "bg-orange-500/20 text-orange-300 border-orange-500/30",
  "2D Game": "bg-pink-500/20 text-pink-300 border-pink-500/30",
};
---

<div class="space-y-8">
  <!-- Filters (optional) -->
  {showFilters && (
    <div class="flex flex-wrap gap-3 justify-center">
      <button 
        class="px-4 py-2 rounded-full bg-gold-500 text-navy-900 font-medium text-sm transition-all duration-300"
        data-filter="all"
      >
        All Projects
      </button>
      {categories.map((cat) => (
        <button 
          class="px-4 py-2 rounded-full bg-white/10 text-white/70 font-medium text-sm hover:bg-white/20 transition-all duration-300"
          data-filter={cat}
        >
          {cat}
        </button>
      ))}
    </div>
  )}

  <!-- Projects Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
    {projects.map((project, index) => (
      <div 
        class="group relative rounded-2xl overflow-hidden bg-navy-800 card-hover animate-on-scroll"
        style={`animation-delay: ${index * 0.1}s;`}
        data-category={project.category}
      >
        <!-- Image Container -->
        <div class="relative aspect-video overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-navy-700 to-navy-900 flex items-center justify-center">
            <!-- Placeholder graphic when no real image -->
            <div class="text-center p-8">
              <div class="w-20 h-20 mx-auto mb-4 rounded-2xl bg-white/10 flex items-center justify-center">
                {project.category === "3D Game" && (
                  <svg class="w-10 h-10 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                  </svg>
                )}
                {project.category === "Mobile App" && (
                  <svg class="w-10 h-10 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
                  </svg>
                )}
                {project.category === "Website" && (
                  <svg class="w-10 h-10 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                  </svg>
                )}
                {project.category === "AI Project" && (
                  <svg class="w-10 h-10 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                )}
              </div>
              <p class="text-white/40 text-sm">Project Preview</p>
            </div>
          </div>
          
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-navy-900 via-navy-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
            <p class="text-white/90 text-sm">
              {project.description}
            </p>
          </div>
        </div>

        <!-- Content -->
        <div class="p-6">
          <div class="flex items-center justify-between gap-4">
            <h3 class="text-lg font-bold text-white group-hover:text-gold-400 transition-colors duration-300">
              {project.title}
            </h3>
            <span class={`px-3 py-1 rounded-full text-xs font-medium border ${categoryColors[project.category] || 'bg-white/10 text-white/70 border-white/20'}`}>
              {project.category}
            </span>
          </div>
        </div>

        <!-- Corner decoration -->
        <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </div>
      </div>
    ))}
  </div>
</div>

<script>
  /**
   * Project Filter Functionality
   * 
   * Handles category filtering for project showcase.
   * Shows/hides projects based on selected category.
   */
  
  const filterBtns = document.querySelectorAll('[data-filter]');
  const projects = document.querySelectorAll('[data-category]');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      
      // Update active button
      filterBtns.forEach((b) => {
        b.classList.remove('bg-gold-500', 'text-navy-900');
        b.classList.add('bg-white/10', 'text-white/70');
      });
      btn.classList.add('bg-gold-500', 'text-navy-900');
      btn.classList.remove('bg-white/10', 'text-white/70');

      // Filter projects
      projects.forEach((project) => {
        const category = project.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          (project as HTMLElement).style.display = 'block';
        } else {
          (project as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
