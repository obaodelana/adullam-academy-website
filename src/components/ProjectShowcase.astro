---
/**
 * ProjectShowcase Component
 * 
 * A grid display for showcasing student projects with hover effects.
 * Used on the Bootcamp page to show what students build.
 * 
 * Features:
 * - Responsive grid layout
 * - Image/GIF support with hover zoom
 * - Category badges
 * - Staggered reveal animations
 * - Optional filtering by category
 * 
 * Props:
 * @prop {Array} projects - Array of project objects
 * @prop {boolean} showFilters - Whether to show category filters
 */

interface Project {
  title: string;
  category: string;
  description: string;
  image: string;
}

interface Props {
  projects?: Project[];
  showFilters?: boolean;
}


const { projects = [], showFilters = false } = Astro.props;

const categories = [...new Set(projects.map(p => p.category))];

// Category colors
const categoryColors: Record<string, string> = {
  "3D Game":    "bg-gold-500/20 text-gold-400 border-gold-500/30",
  "Mobile App": "bg-electric-500/20 text-electric-300 border-electric-500/30",
  "Website":    "bg-gold-400/20 text-gold-300 border-gold-400/30",
  "AI Project": "bg-electric-400/20 text-electric-400 border-electric-400/30",
  "2D Game":    "bg-gold-600/20 text-gold-500 border-gold-600/30",
};
---

<div class="space-y-8">
  <!-- Filters (optional) -->
  {showFilters && (
    <div class="flex flex-wrap gap-3 justify-center">
      <button 
        class="px-4 py-2 rounded-full bg-gold-500 text-navy-900 font-medium text-sm transition-all duration-300"
        data-filter="all"
      >
        All Projects
      </button>
      {categories.map((cat) => (
        <button 
          class="px-4 py-2 rounded-full bg-white/10 text-white/70 font-medium text-sm hover:bg-white/20 transition-all duration-300"
          data-filter={cat}
        >
          {cat}
        </button>
      ))}
    </div>
  )}

  <!-- Projects Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
    {projects.map((project, index) => (
      <div 
        class="group relative rounded-2xl overflow-hidden bg-navy-800 card-hover animate-on-scroll"
        style={`animation-delay: ${index * 0.1}s;`}
        data-category={project.category}
      >
        <!-- Image Container -->
        <div class="relative aspect-video overflow-hidden">
          <div class="absolute inset-0 bg-linear-to-br from-navy-700 to-navy-900 flex items-center justify-center">
						<img
							src={project.image}
							alt={project.title}
							class="w-full h-full object-contain"
						/>
          </div>
          
          <!-- Hover overlay -->
          <div class="absolute inset-0 bg-linear-to-t from-navy-900 via-navy-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
            <p class="text-white/90 text-sm">
              {project.description}
            </p>
          </div>
        </div>

        <!-- Content -->
        <div class="p-6">
          <div class="flex items-center justify-between gap-4">
            <h3 class="text-lg font-bold text-white group-hover:text-gold-400 transition-colors duration-300">
              {project.title}
            </h3>
            <span class={`px-3 py-1 rounded-full text-xs font-medium border ${categoryColors[project.category] || 'bg-white/10 text-white/70 border-white/20'}`}>
              {project.category}
            </span>
          </div>
        </div>

        {/* <!-- Corner decoration -->
        <div class="absolute top-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </div> */}
      </div>
    ))}
  </div>
</div>

<script>
  /**
   * Project Filter Functionality
   * 
   * Handles category filtering for project showcase.
   * Shows/hides projects based on selected category.
   */
  
  const filterBtns = document.querySelectorAll('[data-filter]');
  const projects = document.querySelectorAll('[data-category]');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.getAttribute('data-filter');
      
      // Update active button
      filterBtns.forEach((b) => {
        b.classList.remove('bg-gold-500', 'text-navy-900');
        b.classList.add('bg-white/10', 'text-white/70');
      });
      btn.classList.add('bg-gold-500', 'text-navy-900');
      btn.classList.remove('bg-white/10', 'text-white/70');

      // Filter projects
      projects.forEach((project) => {
        const category = project.getAttribute('data-category');
        if (filter === 'all' || category === filter) {
          (project as HTMLElement).style.display = 'block';
        } else {
          (project as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>
