---
/**
 * SectionHeader Component
 * 
 * Reusable header for page sections with consistent styling.
 * Includes eyebrow text, main heading, and optional description.
 * 
 * Features:
 * - Eyebrow text (small label above heading)
 * - Main heading with gradient option
 * - Optional description text
 * - Centered or left-aligned layouts
 * - Animation ready
 * 
 * Props:
 * @prop {string} eyebrow - Small text above heading
 * @prop {string} title - Main heading text
 * @prop {string} description - Supporting description
 * @prop {boolean} centered - Center align content
 * @prop {boolean} gradient - Use gradient text for title
 * @prop {boolean} light - Light color scheme (for dark backgrounds)
 */

interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  centered?: boolean;
  gradient?: boolean;
  light?: boolean;
}

const {
  eyebrow,
  title,
  description,
  centered = true,
  gradient = false,
  light = false,
} = Astro.props;
---

<div class={`mb-12 lg:mb-16 ${centered ? 'text-center' : ''} animate-on-scroll`}>
  {eyebrow && (
    <p class={`text-sm font-semibold tracking-wider uppercase mb-3 ${light ? 'text-gold-400' : 'text-gold-600'}`}>
      {eyebrow}
    </p>
  )}
  
  <h2 class={`text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-4 leading-tight ${centered ? 'max-w-3xl mx-auto' : ''}`}>
    {gradient ? (
      <span class="gradient-text">{title}</span>
    ) : (
      <span class={light ? 'text-white' : 'text-navy-900'}>{title}</span>
    )}
  </h2>
  
  {description && (
    <p class={`text-lg lg:text-xl leading-relaxed ${centered ? 'max-w-2xl mx-auto' : ''} ${light ? 'text-white/70' : 'text-navy-600'}`}>
      {description}
    </p>
  )}
</div>
