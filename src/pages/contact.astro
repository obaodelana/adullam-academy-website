---
/**
 * Contact Page
 * 
 * Contact information and quick links:
 * - Location with map placeholder
 * - Phone and email
 * - Social media links
 * - Quick registration link
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CTA from '../components/CTA.astro';
import { REGISTER_LINK } from '../data/links';

// Contact information
const contactInfo = {
  phone: "+1 (780) 966-2026",
  phoneRaw: "+17809662026",
  email: "info@adullamacademy.com",
};

// Social links
const socialLinks = [
  {
    name: "Instagram",
    href: "https://www.instagram.com/_adullam.academy_",
    icon: `<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>`
  },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/company/adullamacademy",
    icon: `<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>`
  }
];
---

<BaseLayout 
  title="Contact"
  description="Get in touch with Adullam Academy. Based in Canada, serving online globally."
>
  <!-- Hero Section -->
  <section class="relative min-h-[50vh] flex items-center gradient-hero overflow-hidden">
    <!-- Background elements -->
    <div class="absolute inset-0">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-gold-500/10 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-electric-500/10 rounded-full blur-3xl animate-float" style="animation-delay: -3s;"></div>
    </div>

    <div class="container mx-auto px-4 lg:px-8 py-32 relative z-10 text-center">
      <p class="text-gold-400 font-semibold tracking-wider uppercase mb-4 animate-on-scroll">
        Get In Touch
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6 leading-tight animate-on-scroll">
        Contact <span class="gradient-text">Us</span>
      </h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto animate-on-scroll">
        Have questions? We'd love to hear from you. Reach out and we'll respond as soon as we can.
      </p>
    </div>
  </section>

  <!-- Contact Information Section -->
  <section class="py-24 lg:py-32 bg-cream">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-4xl mx-auto mb-12 text-center">
        <SectionHeader 
          eyebrow="Remote-first"
          title="Based in Canada, serving online globally"
          description="Connect with our team from anywhere. Our live bootcamps are designed for families no matter where you call home."
        />
      </div>
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 max-w-6xl mx-auto">
        
        <!-- Contact Cards -->
        <div class="space-y-6">
          <!-- Phone Card -->
          <div class="group relative p-8 bg-white rounded-2xl shadow-soft border border-navy-100/30 animate-on-scroll card-hover overflow-hidden" style="animation-delay: 0.1s;">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 rounded-2xl bg-linear-to-br from-gold-500/20 to-gold-300/5 flex items-center justify-center shrink-0">
                <svg class="w-7 h-7 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-navy-900 mb-2">Phone</h3>
                <a 
                  href={`tel:${contactInfo.phoneRaw}`}
                  class="text-navy-600/80 hover:text-gold-600 transition-colors text-lg"
                >
                  {contactInfo.phone}
                </a>
              </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-linear-to-r from-gold-500 to-gold-300 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>

          <!-- Email Card -->
          <div class="group relative p-8 bg-white rounded-2xl shadow-soft border border-navy-100/30 animate-on-scroll card-hover overflow-hidden" style="animation-delay: 0.2s;">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 rounded-2xl bg-linear-to-br from-gold-500/20 to-gold-300/5 flex items-center justify-center shrink-0">
                <svg class="w-7 h-7 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-navy-900 mb-2">Email</h3>
                <a
                  href={`mailto:${contactInfo.email}`}
                  class="text-navy-600/80 hover:text-gold-600 transition-colors"
                >
                  {contactInfo.email}
                </a>
              </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-linear-to-r from-gold-500 to-gold-300 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>

          <!-- Social Links Card -->
          <div class="group relative p-8 bg-white rounded-2xl shadow-soft border border-navy-100/30 animate-on-scroll card-hover overflow-hidden" style="animation-delay: 0.3s;">
            <h3 class="text-lg font-bold text-navy-900 mb-4">Follow Us</h3>
            <div class="flex gap-4">
              {socialLinks.map((social) => (
                <a
                  href={social.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="w-12 h-12 rounded-full bg-navy-100 flex items-center justify-center hover:bg-gold-500 hover:scale-110 transition-all duration-300 group"
                  aria-label={`Visit our ${social.name}`}
                >
                  <svg
                    class="w-5 h-5 fill-navy-600 group-hover:fill-navy-900 transition-colors duration-300"
                    viewBox="0 0 24 24"
                    set:html={social.icon}
                  />
                </a>
              ))}
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-linear-to-r from-gold-500 to-gold-300 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>
        </div>

        <!-- Remote Reach / Quick Action -->
        <div class="space-y-6 animate-on-scroll-right">
          <div class="group relative p-8 bg-white rounded-2xl shadow-soft border border-navy-100/30 overflow-hidden">
            <div class="flex items-start gap-4">
              <div class="w-14 h-14 rounded-2xl bg-electric-500/10 flex items-center justify-center shrink-0">
                <svg class="w-8 h-8 text-electric-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2a10 10 0 100 20 10 10 0 000-20z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-navy-900 mb-2">Global Access</h3>
                <p class="text-navy-600/80">
                  We serve families across Canada and beyond through live online bootcamps and mentorship.
                </p>
              </div>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-linear-to-r from-gold-500 to-gold-300 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
          </div>

          <div class="p-8 rounded-2xl gradient-navy text-center">
            <h3 class="text-xl font-bold text-white mb-3">Ready to Register?</h3>
            <p class="text-white/70 mb-6">Join our next bootcamp cohort and start your child's journey.</p>
            <a 
              href={REGISTER_LINK}
              class="btn-primary inline-flex items-center gap-2"
            >
              Register Now
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTA 
    headline="Have More Questions?"
    subtext="Visit our FAQ page for detailed answers about the program, schedule, and what to expect."
    primaryCTA="View FAQs"
    primaryLink="/about#faq"
    variant="minimal"
  />
</BaseLayout>
