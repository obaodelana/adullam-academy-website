---
/**
 * Job Detail Page
 *
 * Displays the full description for a single job listing.
 * Route: /jobs/[slug] (e.g. /jobs/creative-director)
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const jobs = await getCollection("jobs", ({ data }) => data.published === true);
  return jobs.map((job) => ({
    params: { slug: job.slug },
    props: { job },
  }));
}

const { job } = Astro.props;
const { data } = job;

const typeLabels: Record<string, string> = {
  "part-time": "Part-Time",
  "full-time": "Full-Time",
  "contract": "Contract",
  "volunteer": "Volunteer",
};
---

<BaseLayout
  title={`${data.title} | Jobs`}
  description={data.summary}
>
  <!-- Hero -->
  <section class="relative min-h-[35vh] flex items-center gradient-hero overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-1/3 left-1/4 w-80 h-80 bg-gold-500/10 rounded-full blur-3xl animate-float"></div>
      <div class="absolute bottom-1/4 right-1/3 w-72 h-72 bg-electric-500/10 rounded-full blur-3xl animate-float" style="animation-delay: -2s;"></div>
    </div>
    <div class="container mx-auto px-4 lg:px-8 py-28 relative z-10">
      <a
        href="/jobs"
        class="inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium transition-colors mb-6 animate-on-scroll"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Jobs
      </a>
      <div class="flex flex-wrap gap-3 mb-4 animate-on-scroll">
        <span class="px-3 py-1 text-xs font-bold uppercase tracking-wider bg-gold-500/20 text-gold-300 rounded-full">
          {typeLabels[data.type] ?? data.type}
        </span>
        {data.location && (
          <span class="flex items-center gap-1 text-sm text-white/60">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {data.location}
          </span>
        )}
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold text-white animate-on-scroll">{data.title}</h1>
    </div>
  </section>

  <!-- Job Content -->
  <section class="py-24 bg-cream">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-3xl mx-auto space-y-12">

        <!-- Summary Callout -->
        <div class="bg-gold-500/10 border-l-4 border-gold-500 rounded-r-2xl p-6 animate-on-scroll">
          <p class="text-xs font-bold uppercase tracking-widest text-gold-600 mb-3">Role Overview</p>
          <p class="text-navy-800 text-lg leading-relaxed">{data.summary}</p>
        </div>

        <!-- Who We're Looking For -->
        <div class="animate-on-scroll">
          <p class="text-gold-600 font-semibold tracking-wider uppercase text-sm mb-3">Who we're looking for</p>
          <h2 class="text-2xl font-extrabold text-navy-900 mb-6">The 3 key qualities</h2>
          <div class="space-y-4">
            {data.qualities.map((q, i) => (
              <div
                class="bg-white rounded-2xl border border-navy-100 p-6 card-hover animate-on-scroll"
                style={`animation-delay: ${i * 0.1}s;`}
              >
                <div class="flex items-start gap-4">
                  <div class="w-9 h-9 rounded-xl bg-gold-500/15 flex items-center justify-center shrink-0">
                    <span class="text-gold-600 font-extrabold">{i + 1}</span>
                  </div>
                  <div>
                    <h3 class="font-bold text-navy-900 mb-1">{q.label}</h3>
                    <p class="text-navy-600 leading-relaxed">{q.description}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- What success looks like -->
        <div class="border-l-4 border-electric-500 rounded-r-2xl bg-white p-6 animate-on-scroll">
          <p class="text-xs font-bold uppercase tracking-widest text-electric-500 mb-3">What success looks like</p>
          <p class="text-navy-700 leading-relaxed">{data.successLooks}</p>
        </div>

        <!-- Working Style + Compensation -->
        <div class="grid sm:grid-cols-2 gap-6 animate-on-scroll">
          <div class="bg-white rounded-2xl border border-navy-100 p-6">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-xl bg-navy-100 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-navy-900 mb-2">Working Style</h3>
                <p class="text-navy-600 text-sm leading-relaxed">{data.workingStyle}</p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-2xl border border-navy-100 p-6">
            <div class="flex items-start gap-3">
              <div class="w-10 h-10 rounded-xl bg-navy-100 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-navy-900 mb-2">Compensation</h3>
                <p class="text-navy-900 font-semibold">{data.compensationRange}</p>
                {data.compensationNotes && (
                  <p class="text-navy-600 text-sm leading-relaxed mt-1">{data.compensationNotes}</p>
                )}
              </div>
            </div>
          </div>
        </div>

        <!-- Fit Signals -->
        <div class="animate-on-scroll">
          <p class="text-gold-600 font-semibold tracking-wider uppercase text-sm mb-3">Fit signals</p>
          <h2 class="text-2xl font-extrabold text-navy-900 mb-6">You'll be a great fit if...</h2>
          <div class="space-y-3">
            {data.fitSignals.map((signal, i) => (
              <div
                class="flex items-start gap-3 animate-on-scroll"
                style={`animation-delay: ${i * 0.08}s;`}
              >
                <div class="w-6 h-6 rounded-full bg-gold-500/15 flex items-center justify-center shrink-0 mt-0.5">
                  <svg class="w-3.5 h-3.5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <p class="text-navy-700 leading-relaxed">{signal}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Responsibilities (optional) -->
        {data.responsibilities && data.responsibilities.length > 0 && (
          <div class="animate-on-scroll">
            <p class="text-gold-600 font-semibold tracking-wider uppercase text-sm mb-3">Areas you may oversee</p>
            <h2 class="text-2xl font-extrabold text-navy-900 mb-6">What this role covers</h2>
            <div class="bg-white rounded-2xl border border-navy-100 p-6 space-y-3">
              {data.responsibilities.map((item, i) => (
                <div
                  class="flex items-start gap-3 animate-on-scroll"
                  style={`animation-delay: ${i * 0.06}s;`}
                >
                  <div class="w-5 h-5 rounded bg-navy-100 flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-3 h-3 text-navy-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                  <p class="text-navy-700 leading-relaxed text-sm">{item}</p>
                </div>
              ))}
            </div>
          </div>
        )}

      </div>
    </div>
  </section>

  <CTA
    headline="Raising Kingdom Visionaries"
    subtext="While you're here, see what we're building with the next generation."
    primaryCTA="Explore Our Program"
    primaryLink="/bootcamp"
    variant="gradient"
  />
</BaseLayout>
