---
/**
 * Job Detail Page
 *
 * Displays the full description for a single job listing.
 * Route: /career/[slug] (e.g. /career/creative-director)
 */

import BaseLayout from "../../layouts/BaseLayout.astro";
import CTA from "../../components/CTA.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const jobs = await getCollection(
    "jobs",
    ({ data }) => data.published === true,
  );
  return jobs.map((job) => ({
    params: { slug: job.slug },
    props: { job },
  }));
}

const { job } = Astro.props;
const { data } = job;

const typeLabels: Record<string, string> = {
  "part-time": "Part-Time",
  "full-time": "Full-Time",
  contract: "Contract",
  volunteer: "Volunteer",
};
---

<BaseLayout title={`${data.title} | Careers`} description={data.summary}>
  <!-- Hero -->
  <section
    class="relative min-h-[35vh] flex items-center gradient-hero overflow-hidden"
  >
    <div class="absolute inset-0">
      <div
        class="absolute top-1/3 left-1/4 w-80 h-80 bg-gold-500/10 rounded-full blur-3xl animate-float"
      >
      </div>
      <div
        class="absolute bottom-1/4 right-1/3 w-72 h-72 bg-electric-500/10 rounded-full blur-3xl animate-float"
        style="animation-delay: -2s;"
      >
      </div>
    </div>
    <div class="container mx-auto px-4 lg:px-8 py-28 relative z-10">
      <a
        href="/careers"
        class="inline-flex items-center gap-2 text-white/60 hover:text-white text-sm font-medium transition-colors mb-6 animate-on-scroll"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        Back to Careers
      </a>
      <div class="flex flex-wrap gap-3 mb-4 animate-on-scroll">
        <span
          class="px-3 py-1 text-xs font-bold uppercase tracking-wider bg-gold-500/20 text-gold-300 rounded-full"
        >
          {typeLabels[data.type] ?? data.type}
        </span>
        {
          data.location && (
            <span class="flex items-center gap-1 text-sm text-white/60">
              <svg
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                />
              </svg>
              {data.location}
            </span>
          )
        }
      </div>
      <h1
        class="text-4xl sm:text-5xl font-extrabold text-white animate-on-scroll"
      >
        {data.title}
      </h1>
    </div>
  </section>

  <!-- Job Content -->
  <section class="py-24 bg-cream">
    <div class="container mx-auto px-4 lg:px-8">
      <div class="max-w-3xl mx-auto space-y-12">
        <!-- Summary Callout -->
        <div
          class="bg-gold-500/10 border-l-4 border-gold-500 rounded-r-2xl p-6 animate-on-scroll"
        >
          <p
            class="text-xs font-bold uppercase tracking-widest text-gold-600 mb-3"
          >
            Role Overview
          </p>
          <p class="text-navy-800 text-lg leading-relaxed">{data.summary}</p>
        </div>

        <!-- Who We're Looking For -->
        <div class="animate-on-scroll">
          <p
            class="text-gold-600 font-semibold tracking-wider uppercase text-sm mb-3"
          >
            Who we're looking for
          </p>
          <h2 class="text-2xl font-extrabold text-navy-900 mb-6">
            The 3 key qualities
          </h2>
          <div class="space-y-4">
            {
              data.qualities.map((q, i) => (
                <div
                  class="bg-white rounded-2xl border border-navy-100 p-6 card-hover animate-on-scroll"
                  style={`animation-delay: ${i * 0.1}s;`}
                >
                  <div class="flex items-start gap-4">
                    <div class="w-9 h-9 rounded-xl bg-gold-500/15 flex items-center justify-center shrink-0">
                      <span class="text-gold-600 font-extrabold">{i + 1}</span>
                    </div>
                    <div>
                      <h3 class="font-bold text-navy-900 mb-1">{q.label}</h3>
                      <p class="text-navy-600 leading-relaxed">
                        {q.description}
                      </p>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <!-- What success looks like -->
        <div
          class="border-l-4 border-electric-500 rounded-r-2xl bg-white p-6 animate-on-scroll"
        >
          <p
            class="text-xs font-bold uppercase tracking-widest text-electric-500 mb-3"
          >
            What success looks like
          </p>
          <p class="text-navy-700 leading-relaxed">{data.successLooks}</p>
        </div>

        <!-- Why build with us -->
        {
          data.benefits && data.benefits.length >= 4 && (
            <div class="animate-on-scroll">
              <div class="flex flex-col items-center text-center mb-12">
                <p class="text-gold-600 font-bold tracking-[0.2em] uppercase text-xs mb-4">
                  Growth & Impact
                </p>
                <h2 class="text-3xl sm:text-4xl font-extrabold text-navy-900">
                  Why build with us?
                </h2>
                <div class="w-16 h-1 bg-gold-500 mt-6 rounded-full" />
              </div>

              <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
                {/* Card 1: Wide/Dark */}
                <div class="md:col-span-7 bg-navy-900 rounded-4xl p-8 text-white relative overflow-hidden group animate-on-scroll">
                  <div class="absolute top-0 right-0 w-32 h-32 bg-gold-500/10 rounded-full blur-3xl -mr-16 -mt-16 group-hover:bg-gold-500/20 transition-colors" />
                  <div class="relative z-10 flex flex-col h-full justify-between">
                    <div class="w-14 h-14 rounded-2xl bg-white/10 flex items-center justify-center mb-8">
                      <svg
                        class="w-7 h-7 text-gold-400"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M13 10V3L4 14h7v7l9-11h-7z"
                        />
                      </svg>
                    </div>
                    <div>
                      <h3 class="text-2xl font-bold mb-3">
                        {data.benefits[0].title}
                      </h3>
                      <p class="text-white/70 leading-relaxed text-sm lg:text-base">
                        {data.benefits[0].description}
                      </p>
                    </div>
                  </div>
                </div>

                {/* Card 2: Tall/Light */}
                <div
                  class="md:col-span-5 bg-white rounded-4xl p-8 border border-navy-100 shadow-soft relative overflow-hidden group animate-on-scroll"
                  style="animation-delay: 0.1s;"
                >
                  <div class="absolute -bottom-12 -right-12 w-32 h-32 bg-navy-900/5 rounded-full blur-2xl group-hover:bg-navy-900/10 transition-colors" />
                  <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-gold-500/10 flex items-center justify-center mb-6">
                      <svg
                        class="w-7 h-7 text-gold-600"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"
                        />
                      </svg>
                    </div>
                    <h3 class="text-xl font-bold text-navy-900 mb-3">
                      {data.benefits[1].title}
                    </h3>
                    <p class="text-navy-600 leading-relaxed text-sm">
                      {data.benefits[1].description}
                    </p>
                  </div>
                </div>

                {/* Card 3: Tall/Cream */}
                <div
                  class="md:col-span-5 bg-white rounded-4xl p-8 border border-navy-100 shadow-soft relative overflow-hidden group animate-on-scroll"
                  style="animation-delay: 0.2s;"
                >
                  <div class="absolute -top-12 -left-12 w-32 h-32 bg-electric-500/5 rounded-full blur-2xl group-hover:bg-electric-500/10 transition-colors" />
                  <div class="relative z-10">
                    <div class="w-14 h-14 rounded-2xl bg-electric-500/10 flex items-center justify-center mb-6">
                      <svg
                        class="w-7 h-7 text-electric-500"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"
                        />
                      </svg>
                    </div>
                    <h3 class="text-xl font-bold text-navy-900 mb-3">
                      {data.benefits[2].title}
                    </h3>
                    <p class="text-navy-600 leading-relaxed text-sm">
                      {data.benefits[2].description}
                    </p>
                  </div>
                </div>

                {/* Card 4: Wide/Gold */}
                <div
                  class="md:col-span-7 bg-linear-to-br from-gold-500 to-gold-600 rounded-4xl p-8 text-white relative overflow-hidden group animate-on-scroll"
                  style="animation-delay: 0.3s;"
                >
                  <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -mr-32 -mt-32" />
                  <div class="relative z-10 flex flex-col h-full justify-between">
                    <div class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center mb-8">
                      <svg
                        class="w-7 h-7 text-white"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                        />
                      </svg>
                    </div>
                    <div>
                      <h3 class="text-2xl font-bold mb-3">
                        {data.benefits[3].title}
                      </h3>
                      <p class="text-white/90 leading-relaxed text-sm lg:text-base">
                        {data.benefits[3].description}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          )
        }

        <!-- Working Style + Compensation -->
        <div class="grid sm:grid-cols-2 gap-6 animate-on-scroll">
          <div class="bg-white rounded-2xl border border-navy-100 p-6">
            <div class="flex items-start gap-3">
              <div
                class="w-10 h-10 rounded-xl bg-navy-100 flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-navy-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-navy-900 mb-2">Working Style</h3>
                <p class="text-navy-600 text-sm leading-relaxed">
                  {data.workingStyle}
                </p>
              </div>
            </div>
          </div>
          <div class="bg-white rounded-2xl border border-navy-100 p-6">
            <div class="flex items-start gap-3">
              <div
                class="w-10 h-10 rounded-xl bg-navy-100 flex items-center justify-center shrink-0"
              >
                <svg
                  class="w-5 h-5 text-navy-600"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  ></path>
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-navy-900 mb-2">Compensation</h3>
                <p class="text-navy-900 font-semibold">
                  {data.compensationRange}
                </p>
                {
                  data.compensationNotes && (
                    <p class="text-navy-600 text-sm leading-relaxed mt-1">
                      {data.compensationNotes}
                    </p>
                  )
                }
              </div>
            </div>
          </div>
        </div>

        <!-- Fit Signals -->
        <div class="animate-on-scroll">
          <p
            class="text-gold-600 font-semibold tracking-wider uppercase text-sm mb-3"
          >
            Fit signals
          </p>
          <h2 class="text-2xl font-extrabold text-navy-900 mb-6">
            You'll be a great fit if...
          </h2>
          <div class="space-y-3">
            {
              data.fitSignals.map((signal, i) => (
                <div
                  class="flex items-start gap-3 animate-on-scroll"
                  style={`animation-delay: ${i * 0.08}s;`}
                >
                  <div class="w-6 h-6 rounded-full bg-gold-500/15 flex items-center justify-center shrink-0 mt-0.5">
                    <svg
                      class="w-3.5 h-3.5 text-gold-600"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                  </div>
                  <p class="text-navy-700 leading-relaxed">{signal}</p>
                </div>
              ))
            }
          </div>
        </div>

        <!-- Responsibilities (optional) -->
        {
          data.responsibilities && data.responsibilities.length > 0 && (
            <div class="animate-on-scroll">
              <p class="text-gold-600 font-semibold tracking-wider uppercase text-sm mb-3">
                Areas you may oversee
              </p>
              <h2 class="text-2xl font-extrabold text-navy-900 mb-6">
                What this role covers
              </h2>
              <div class="bg-white rounded-2xl border border-navy-100 p-6 space-y-3">
                {data.responsibilities.map((item, i) => (
                  <div
                    class="flex items-start gap-3 animate-on-scroll"
                    style={`animation-delay: ${i * 0.06}s;`}
                  >
                    <div class="w-5 h-5 rounded bg-navy-100 flex items-center justify-center shrink-0 mt-0.5">
                      <svg
                        class="w-3 h-3 text-navy-600"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2.5"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                    </div>
                    <p class="text-navy-700 leading-relaxed text-sm">{item}</p>
                  </div>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <CTA
    headline="Raising Kingdom Visionaries"
    subtext="While you're here, see what we're building with the next generation."
    primaryCTA="Explore Our Program"
    primaryLink="/bootcamp"
    variant="gradient"
  />
</BaseLayout>
